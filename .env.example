# Choose which PostgreSQL database this app connects to.
# Use local on your machine and neon on hosting.
DB_TARGET=local

# Choose which databases `python create_table.py` syncs.
CREATE_TABLE_TARGETS=local,neon

# When true, API create/update/delete writes are copied to the other configured database.
# Example: DB_TARGET=local writes local first, then mirrors to Neon.
MIRROR_DATABASE_WRITES=false

# Optional single override. If DATABASE_URL is set, it is used before DB_TARGET.
# DATABASE_URL=

# Neon / hosted PostgreSQL. Keep sslmode=require.
# NEON_DATABASE_URL=postgresql://neondb_owner:your_password@your-neon-host.neon.tech/Portfolio?sslmode=require
NEON_DATABASE_URL=

# Local PostgreSQL connection string. You can use this or the separate DB_* values below.
LOCAL_DATABASE_URL=

# Local PostgreSQL fallback. These are used when DB_TARGET=local and LOCAL_DATABASE_URL is empty.
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=your_db_name

# Option 1: copy the full value from Cloudinary API Keys.
# CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Option 2: use separate values.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloud_api_key
CLOUDINARY_API_SECRET=your_cloud_api_secret

# Optional parent folder for all uploads.
CLOUDINARY_FOLDER_PREFIX=hav-portfolio

# Optional: set this to an enabled unsigned upload preset if your API key is restricted.
# CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
